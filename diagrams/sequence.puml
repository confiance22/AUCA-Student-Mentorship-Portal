@startuml
title AUCA Student Mentorship Portal - Sequence Diagram

actor Mentee
actor Mentor
actor Admin
participant "Portal Website" as UI
participant "Portal System" as Server
participant "Status Tracker" as Status
participant "Notification Sender" as Notif
database "Database" as DB

== User Registration ==
Mentee -> UI : opens the portal
UI -> Server : submits registration details
Server -> DB : saves new user
DB --> Server : user saved
Server --> UI : registration successful
UI --> Mentee : shows success message

== Mentee Books a Session ==
Mentee -> UI : browses available mentors
UI -> Server : requests mentor list
Server -> DB : fetches mentors
DB --> Server : returns mentor list
Server --> UI : displays mentors
Mentee -> UI : selects a mentor and books session
UI -> Server : sends booking request
Server -> Status : mark session as Pending
Status -> DB : saves Pending
DB --> Status : confirmed
Status --> Server : status updated
Server --> UI : booking confirmed
UI --> Mentee : session is Pending

== Mentor Responds to Session Request ==
Mentor -> UI : views incoming session requests
UI -> Server : requests pending sessions
Server -> DB : fetches pending sessions
DB --> Server : returns session list
Server --> UI : shows session requests
Mentor -> UI : accepts or declines session

alt Mentor Accepts
    UI -> Server : sends acceptance
    Server -> Status : mark session as Accepted
    Status -> DB : saves Accepted
    DB --> Status : confirmed
    Server -> Notif : tell mentee session is accepted
    Notif --> Mentee : your session has been accepted
    Server --> UI : session accepted
    UI --> Mentor : acceptance confirmed

    == Session Completion ==
    Mentee -> UI : attends the session
    Mentor -> UI : marks session as complete
    UI -> Server : sends completion update
    Server -> Status : mark session as Completed
    Status -> DB : saves Completed
    DB --> Status : confirmed
    Server --> UI : session marked complete

    == Mentee Gives Feedback ==
    Mentee -> UI : writes and submits feedback
    UI -> Server : sends feedback
    Server -> DB : saves feedback
    DB --> Server : feedback saved
    Server --> UI : feedback received
    UI --> Mentee : thank you for your feedback

else Mentor Declines
    UI -> Server : sends decline
    Server -> Status : mark session as Declined
    Status -> DB : saves Declined
    DB --> Status : confirmed
    Server -> Notif : tell mentee session is declined
    Notif --> Mentee : your session has been declined
    Server --> UI : session declined
    UI --> Mentor : decline confirmed
end

== Student Applies to Become a Mentor ==
Mentee -> UI : fills in mentor application form
UI -> Server : submits application
Server -> Status : mark application as Pending Approval
Status -> DB : saves Pending Approval
DB --> Status : confirmed
Server --> UI : application submitted
UI --> Mentee : your application is under review

== Admin Reviews Mentor Application ==
Admin -> UI : logs in and opens applications
UI -> Server : requests pending applications
Server -> DB : fetches applications
DB --> Server : returns applications
Server --> UI : shows pending applications

alt Admin Approves
    Admin -> UI : clicks approve
    UI -> Server : sends approval
    Server -> Status : mark application as Approved
    Status -> DB : saves Approved
    DB --> Status : confirmed
    Server -> Notif : tell applicant they are approved
    Notif --> Mentee : your mentor application was approved
    Server --> UI : application approved
    UI --> Admin : approval confirmed

else Admin Rejects
    Admin -> UI : clicks reject
    UI -> Server : sends rejection
    Server -> Status : mark application as Rejected
    Status -> DB : saves Rejected
    DB --> Status : confirmed
    Server -> Notif : tell applicant they are rejected
    Notif --> Mentee : your mentor application was rejected
    Server --> UI : application rejected
    UI --> Admin : rejection confirmed
end

@enduml