@startuml
title AUCA Mentorship Portal - Component Diagram

package "Frontend" {
    [React App] as React
    [Auth Context] as Auth
    [Role Selector] as RoleSelector
}

package "Backend" {
    [Express Server] as Express
    [JWT Middleware] as JWT
    [Auth Routes] as AuthR
    [User Routes] as UserR
    [Session Routes] as SessionR
    [Feedback Routes] as FeedbackR
    [Mentor Application Routes] as MentorAppR
    [Status Service] as StatusSvc
    [Notification Service] as NotifSvc
}

package "Database" {
    [PostgreSQL] as DB
    [Users Table] as Users
    [Sessions Table] as Sessions
    [Feedback Table] as Feedbacks
    [Mentor Applications Table] as MentorApps
}

[Browser] as Browser

Browser --> React : opens the app
React --> Auth : checks login state
React --> RoleSelector : picks a role
RoleSelector --> Express : sends chosen role
React --> Express : makes requests
Express --> JWT : checks identity
Express --> AuthR : login and register
Express --> UserR : manage users
Express --> SessionR : manage sessions
Express --> FeedbackR : manage feedback
Express --> MentorAppR : manage mentor applications
SessionR --> StatusSvc : updates session status
MentorAppR --> StatusSvc : updates application status
SessionR --> NotifSvc : notifies mentee of decision
MentorAppR --> NotifSvc : notifies applicant of outcome
AuthR --> DB : reads and writes
UserR --> DB : reads and writes
SessionR --> DB : reads and writes
FeedbackR --> DB : reads and writes
MentorAppR --> DB : reads and writes
StatusSvc --> DB : saves status changes
DB --> Users : stores user records
DB --> Sessions : stores session records
DB --> Feedbacks : stores feedback records
DB --> MentorApps : stores application records

@enduml