@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title AUCA Student Mentorship Portal - Use Case Diagram

' ACTORS on LEFT side
actor "Mentee" as Mentee
actor "Mentor" as Mentor

rectangle "Mentorship Portal System" {
    
    usecase "Register\nAccount" as UC1
    usecase "Login" as UC2
    usecase "Logout" as UC3
    
    usecase "Browse\nMentors" as UC4
    usecase "Book\nSession" as UC5
    usecase "View My\nSessions" as UC6
    usecase "Cancel\nSession" as UC7
    
    usecase "Accept or\nDecline Session" as UC8
    usecase "Mark Session\nComplete" as UC9
    
    usecase "Submit\nFeedback" as UC10
    usecase "View Received\nFeedback" as UC11
    
    usecase "Apply as\nMentor" as UC12
    usecase "Approve Mentor\nApplication" as UC13
    usecase "View System\nReports" as UC14
}

' ACTOR on RIGHT side
actor "Admin\nUser" as Admin

' MENTEE relationships (left side)
Mentee --> UC1
Mentee --> UC2
Mentee --> UC3
Mentee --> UC4
Mentee --> UC5
Mentee --> UC6
Mentee --> UC7
Mentee --> UC10
Mentee --> UC12

' MENTOR relationships (left side)
Mentor --> UC1
Mentor --> UC2
Mentor --> UC3
Mentor --> UC6
Mentor --> UC8
Mentor --> UC9
Mentor --> UC11

' ADMIN relationships (right side)
Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC13
Admin --> UC14

' INCLUDE and EXTEND
UC5 ..> UC6 : <<include>>
UC10 ..> UC9 : <<extend>>

note left of UC13
  Only Admin User can 
  approve mentor applications
end note

@enduml