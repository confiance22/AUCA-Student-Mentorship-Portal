@startuml AUCA_Mentorship_ActivityDiagram

skinparam backgroundColor white
skinparam ArrowColor #185FA5
skinparam ActivityBackgroundColor #E6F1FB
skinparam ActivityBorderColor #185FA5
skinparam ActivityDiamondBackgroundColor #FAEEDA
skinparam ActivityDiamondBorderColor #633806
skinparam StartColor #185FA5
skinparam EndColor #185FA5

title ACTIVITY DIAGRAM FOR AUCA STUDENT MENTORSHIP PORTAL

|Admin User|
start
:Manage System;

|Mentor User|
:Apply as Mentor;

|Admin User|
:Review Application;

if (Approved?) then (yes)
    :Activate Mentor Account;
else (no)
    :Reject Application;
    |Mentor User|
    :Receive Rejection;
    stop
endif

|Mentee User|
:Register Account;
:Login to System;

if (Valid Credentials?) then (yes)
    :Access Dashboard;
else (no)
    :Show Error;
    stop
endif

:Complete Profile;
:Browse Mentor Directory;

while (Mentor Selected?) is (no)
    :Search by Department/Expertise;
    
    if (Mentor Found?) then (yes)
        :View Mentor Profile;
        :Check Availability;
        
        if (Available?) then (yes)
            :Select Mentor;
        else (no)
            :View Other Mentors;
        endif
    else (no)
        :Refine Search Criteria;
    endif
endwhile (yes)

:Book Session\n(Select date, time, topic);
:Submit Booking Request;

|Mentor User|
:Receive Booking Notification;
:Review Request;

if (Accept Request?) then (yes)
    :Confirm Session;
    
    |Mentee User|
    :Receive Confirmation;
    
    fork
        :Attend Session;
    fork again
        |Mentor User|
        :Prepare for Session;
    end fork
    
    if (Session Completed?) then (yes)
        :Mark as Completed;
        
        fork
            |Mentee User|
            :Submit Feedback & Rating;
        fork again
            |Mentor User|
            :View Feedback;
        end fork
        
    else (cancelled)
        :Cancel Session;
        :Notify Cancellation;
    endif
    
else (no)
    :Decline Request;
    
    |Mentee User|
    :Receive Decline Notification;
    :Return to Browse;
    detach
endif

|Admin User|
:Generate Session Reports;
:Monitor System Activity;
stop

@enduml