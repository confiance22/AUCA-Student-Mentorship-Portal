@startuml
title AUCA Student Mentorship Portal - Activity Diagram



legend right
  | Swimlane | Meaning |
  | Any User | Any User (Mentor/Mentee/Admin) |
  | Mentee | Mentee User (Student) |
  | Mentor | Mentor User (Senior Student/Lecturer) |
  | Admin | Admin User (System Administrator) |
endlegend

|Any User|
start
:Register Account;
:Select Role;

if (Role is Mentee?) then (yes)
  
  |Mentee|
  :Login;
  :Browse Mentors;
  :Select Mentor;
  :Book Session;
  :System Creates Session;
  :Status PENDING;
  
  |Mentor|
  :View Request;
  :Make Decision;
  
  if (Accept?) then (yes)
    :Accept Session;
    :Status ACCEPTED;
    :Mentee Attends;
    :Mark Complete;
    :Status COMPLETED;
    :Mentee Gives Feedback;
    :Store Feedback;
    stop
    
  else (no)
    :Decline Session;
    :Status DECLINED;
    stop
  endif
  
else (no)
  
  |Any User|
  if (Role is Mentor Applicant?) then (yes)
    
    |Mentor|
    :Apply as Mentor;
    :Status PENDING_APPROVAL;
    
    |Admin|
    :Review Application;
    
    if (Approve?) then (yes)
      :Approve Mentor;
      :Status APPROVED;
      
      |Mentor|
      :Login as Mentor;
      :Manage Sessions;
      stop
      
    else (no)
      :Reject Application;
      :Status REJECTED;
      stop
    endif
    
  else (no)
    
    |Admin|
    :Login as Admin;
    :Manage System;
    stop
    
  endif

endif

@enduml